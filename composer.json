{
  "name": "paulo-cruz/projeto-futsal",
  "description": "Sistema web simples para organizar pelada/futsal com Slim Framework",
  "type": "project",
  "require": {
    "php": "^8.2",
    "slim/slim": "^4.13",
    "slim/psr7": "^1.7",
    "php-di/php-di": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8500 -t public",
    "backup-players": "php bin/backup_players.php",
    "reset-tests": "php bin/reset_sessions.php",
    "create-supervisor": "php bin/create_supervisor.php",
    "post-install-cmd": [
      "@php -r \"if (!file_exists('storage/database.sqlite')) { touch('storage/database.sqlite'); }\""
    ],
    "post-update-cmd": [
      "@php -r \"if (!file_exists('storage/database.sqlite')) { touch('storage/database.sqlite'); }\""
    ]
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
